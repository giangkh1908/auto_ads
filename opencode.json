{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/qwen3-coder-plus",
  "small_model": "opencode/qwen3-coder",
  "default_agent": "build",
  "formatter": true,
  "instructions": [
    "AGENTS.md",
    "backend/AGENTS.md",
    "frontend/AGENTS.md"
  ],
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "task": "allow"
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "coverage/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
